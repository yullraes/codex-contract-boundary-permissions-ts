{
  "name": "contract-boundary-permission-bundle",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Codex plugin bundle for contract-boundary permission automation.",
  "scripts": {
    "analyze:imports": "node src/analyze-js-ts-imports.ts",
    "generate:permissions": "node src/generate-codex-permissions.ts",
    "generate:rules": "node src/generate-codex-rules.ts",
    "scan:boundaries": "node scripts/scan-boundaries.mjs",
    "refresh:generated": "node scripts/refresh-generated.mjs",
    "check:generated": "node scripts/refresh-generated.mjs --check",
