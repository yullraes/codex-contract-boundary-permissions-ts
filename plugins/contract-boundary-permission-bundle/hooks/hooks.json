{
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$(git rev-parse --show-toplevel)/.codex/tools/contract-boundary-permissions/hooks/stop-checks.mjs\" --workspace \"$(git rev-parse --show-toplevel)\" --tool-root \"$(git rev-parse --show-toplevel)/.codex/tools/contract-boundary-permissions\"",
            "commandWindows": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"$root = git rev-parse --show-toplevel; node (Join-Path $root '.codex/tools/contract-boundary-permissions/hooks/stop-checks.mjs') --workspace $root --tool-root (Join-Path $root '.codex/tools/contract-boundary-permissions')\"",
            "timeout": 120,
            "statusMessage": "Checking contract-boundary permissions"
          }
        ]
      }
    ]
  }
}
